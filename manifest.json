{
  "manifest_version": 3,
  "name": "Slopdetector - AI Content Detector",
  "version": "1.1.0",
  "description": "Detect AI-generated content on social media using LLM API providers or LM Studio",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.reddit.com/*",
        "https://old.reddit.com/*"
      ],
      "js": [
        "shared/config.js",
        "content/core.js",
        "content/reddit.js"
      ],
      "css": [
        "content/styles.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "shared/config.js",
        "content/core.js",
        "content/linkedin.js"
      ],
      "css": [
        "content/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/slopmoji.png"
      ],
      "matches": [
        "https://www.reddit.com/*",
        "https://old.reddit.com/*",
        "https://www.linkedin.com/*"
      ]
    }
  ]
}